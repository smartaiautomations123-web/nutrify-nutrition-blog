---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Nutrition &amp; Health Guides</h1>
			<p>
				Practical, evidence-based guides on nutrition, fitness, and healthy habits — written by the
				team behind <a href="https://nutrify.info">Nutrify AI</a>, the AI-powered app that scans your
				meals, tracks your macros, and coaches you toward your goals.
			</p>
			<p>
				No fads, no fluff. Just clear, science-backed advice you can actually use — whether you're
				trying to eat more protein, lose weight sustainably, or simply understand what's on your plate.
			</p>
			<p>
				<a href="/blog"><strong>Browse the latest articles →</strong></a>
			</p>
			<p>
				Want it all in one place? <a href="https://nutrify.info">Try Nutrify AI</a> — snap a photo of
				any meal and get instant nutrition insights, personalised plans, and 24/7 coaching.
			</p>
		</main>
		<Footer />
	</body>
</html>
